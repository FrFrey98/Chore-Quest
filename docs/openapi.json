          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          },
          "conditionType": {
            "type": "string",
            "enum": [
              "task_count",
              "category_count",
              "streak_days",
              "total_points",
              "level"
            ]
          },
          "conditionValue": {
            "type": "integer",
            "minimum": 0
          },
          "conditionMeta": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "sortOrder": {
            "type": "integer",
            "default": 0
          }
        },
        "required": [
          "title",
          "description",
          "emoji",
          "conditionType",
          "conditionValue"
        ]
      },
      "UpdateAchievement": {
