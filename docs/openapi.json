{
  "openapi": "3.1.0",
  "info": {
    "title": "Chore Quest API",
    "version": "1.1.0",
    "description": "REST API for Chore Quest — a gamified household task manager."
  },
  "components": {
    "schemas": {
      "CreateTask": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          },
          "points": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "categoryId": {
            "type": "string",
            "minLength": 1
          },
          "isRecurring": {
            "type": [
              "boolean",
              "null"
            ],
            "default": false
          },
          "recurringInterval": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "allowMultiple": {
            "type": [
              "boolean",
              "null"
            ],
            "default": false
          },
          "dailyLimit": {
            "type": [
              "integer",
              "null"
            ],
            "exclusiveMinimum": 0,
            "default": null
          },
          "scheduleDays": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-6](,[0-6])*$",
            "default": null
          },
          "scheduleTime": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "assignedUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        },
        "required": [
          "title",
          "emoji",
          "points",
          "categoryId"
        ]
      },
      "UpdateTask": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          },
          "points": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "isRecurring": {
            "type": [
              "boolean",
              "null"
            ],
            "default": false
          },
          "recurringInterval": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "allowMultiple": {
            "type": [
              "boolean",
              "null"
            ],
            "default": false
          },
          "dailyLimit": {
            "type": [
              "integer",
              "null"
            ],
            "exclusiveMinimum": 0,
            "default": null
          },
          "scheduleDays": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-6](,[0-6])*$",
            "default": null
          },
          "scheduleTime": {
            "type": [
              "string",
              "null"
            ],
            "default": null
          },
          "assignedUserIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "categoryId": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "archived"
            ]
          }
        }
      },
      "CreateUser": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50
          },
          "pin": {
            "type": "string",
            "pattern": "^\\d{4,8}$"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member",
              "child"
            ],
            "default": "member"
          }
        },
        "required": [
          "name",
          "pin"
        ]
      },
      "CreateCategory": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "emoji": {
            "type": "string",
            "minLength": 1
          }
        },
