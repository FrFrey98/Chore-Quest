generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  admin
  member
  child
}

model User {
  id          String   @id @default(cuid())
  name        String
  pin         String
  role        Role     @default(member)
  locale      String   @default("en")
  createdAt   DateTime @default(now())
  notificationsEnabled     Boolean @default(false)
  installPromptDismissed   Boolean @default(false)
  telegramChatId   String?
  ntfyEnabled      Boolean  @default(false)
  vacationStart DateTime?
  vacationEnd   DateTime?

  completions        TaskCompletion[]
  purchases          Purchase[]
  createdTasks       Task[]           @relation("CreatedBy")
  approvedTasks      Task[]           @relation("ApprovedBy")
  approvals          TaskApproval[]
  userAchievements   UserAchievement[]
  streakState        StreakState?
  sharedCompletions  TaskCompletion[] @relation("sharedCompletions")
  pushSubscriptions  PushSubscription[]
  assignedTasks      Task[]           @relation("TaskAssignments")
  userChallenges     UserChallenge[]
  userQuests         UserQuest[]
  createdQuests        Quest[]          @relation("QuestCreatedBy")
  dogSessions          DogTrainingSession[] @relation("DogSessionUser")
  dogSessionsWith      DogTrainingSession[] @relation("DogSessionWithUser")
  createdDogSkills     DogSkillDefinition[] @relation("DogSkillCreatedBy")
  dogUserAchievements  UserDogAchievement[] @relation("DogUserAchievement")
}

model Category {
  id         String      @id @default(cuid())
  name       String
  emoji      String
  isSystem   Boolean     @default(false)
  tasks      Task[]
  challenges Challenge[]
}

model Task {
  id                String    @id @default(cuid())
  title             String
  emoji             String
  points            Int
  isRecurring       Boolean   @default(false)
  recurringInterval String?
  status            String    @default("pending_approval")
  categoryId        String
  createdById       String
  approvedById      String?
  createdAt         DateTime  @default(now())
  nextDueAt         DateTime?
  allowMultiple     Boolean   @default(false)
  dailyLimit        Int?
  scheduleDays      String?
  scheduleTime      String?
  decayHours        Int?
  lastNotifiedAt    DateTime?
  isSystem          Boolean   @default(false)
  dogId             String?

  category          Category               @relation(fields: [categoryId], references: [id])
  createdBy         User                   @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy        User?                  @relation("ApprovedBy", fields: [approvedById], references: [id])
  completions       TaskCompletion[]
  approval          TaskApproval?
  scheduleOverrides TaskScheduleOverride[]
  assignedUsers     User[]               @relation("TaskAssignments")
  questSteps        QuestStep[]
}

model TaskApproval {
  id            String   @id @default(cuid())
  taskId        String   @unique
  requestedById String
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  task        Task @relation(fields: [taskId], references: [id])
  requestedBy User @relation(fields: [requestedById], references: [id])
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  points      Int
  completedAt DateTime @default(now())
  withUserId  String?

  task     Task  @relation(fields: [taskId], references: [id])
  user     User  @relation(fields: [userId], references: [id])
  withUser User? @relation("sharedCompletions", fields: [withUserId], references: [id])
  dogSessions DogTrainingSession[]

  @@index([withUserId])
}

model StoreItem {
  id          String   @id @default(cuid())
  title       String
  description String
  emoji       String
  pointCost   Int
  type        String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  purchases Purchase[]
}

model Purchase {
  id          String    @id @default(cuid())
  itemId      String
  userId      String
  pointsSpent Int
  purchasedAt DateTime  @default(now())
  redeemedAt  DateTime?
  notifiedAt  DateTime?

  item StoreItem @relation(fields: [itemId], references: [id])
  user User      @relation(fields: [userId], references: [id])
}

model Achievement {
  id             String   @id @default(cuid())
  title          String
  description    String
  emoji          String
  conditionType  String   // 'task_count', 'category_count', 'streak_days', 'total_points', 'level'
  conditionValue Int
  conditionMeta  String?  // e.g. categoryId for category_count
  sortOrder      Int      @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
}

model StreakState {
  id             String    @id @default(cuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  bestStreak     Int       @default(0)
  lastActiveAt   DateTime?
  restoreCount   Int       @default(0)
  lastRestoredAt DateTime?
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model TaskScheduleOverride {
  id     String @id @default(cuid())
  taskId String
  date   String
  type   String // "add" or "skip"

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, date])
  @@index([taskId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Challenge {
  id            String   @id @default(cuid())
  type          String   // 'task_count', 'category_count', 'streak_days', 'teamwork_count'
  title         String
  titleDe       String
  description   String
  descriptionDe String
  emoji         String
  targetValue   Int
  bonusPoints   Int
  weekStart     DateTime
  weekEnd       DateTime
  categoryId    String?  // Only for category_count type
  createdAt     DateTime @default(now())

  category       Category?       @relation(fields: [categoryId], references: [id])
  userChallenges UserChallenge[]
}

model UserChallenge {
  id              String    @id @default(cuid())
  userId          String
  challengeId     String
  currentProgress Int       @default(0)
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([challengeId])
}

model Quest {
  id            String   @id @default(cuid())
  title         String
  titleDe       String
  description   String
  descriptionDe String
  emoji         String
  bonusPoints   Int
  isActive      Boolean  @default(true)
  createdById   String
  createdAt     DateTime @default(now())

  createdBy  User        @relation("QuestCreatedBy", fields: [createdById], references: [id])
  steps      QuestStep[]
  userQuests UserQuest[]
}

model QuestStep {
  id            String @id @default(cuid())
  questId       String
  stepOrder     Int
  taskId        String
  description   String
  descriptionDe String

  quest          Quest           @relation(fields: [questId], references: [id], onDelete: Cascade)
  task           Task            @relation(fields: [taskId], references: [id])
  userQuestSteps UserQuestStep[]

  @@index([questId])
}

model UserQuest {
  id               String    @id @default(cuid())
  userId           String
  questId          String
  currentStepOrder Int       @default(1)
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest          Quest           @relation(fields: [questId], references: [id], onDelete: Cascade)
  userQuestSteps UserQuestStep[]

  @@unique([userId, questId])
  @@index([questId])
}

model UserQuestStep {
  id          String    @id @default(cuid())
  userQuestId String
  questStepId String
  completedAt DateTime?

  userQuest UserQuest @relation(fields: [userQuestId], references: [id], onDelete: Cascade)
  questStep QuestStep @relation(fields: [questStepId], references: [id], onDelete: Cascade)

  @@unique([userQuestId, questStepId])
}

model Dog {
  id             String    @id @default(cuid())
  name           String
  emoji          String    @default("🐕")
  photoBase64    String?
  breed          String?
  gender         String?
  birthDate      DateTime?
  phase          String    @default("adult")
  notes          String?
  vacationStart  DateTime?
  vacationEnd    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  skills           DogSkillProgress[]
  sessions         DogTrainingSession[]
  userAchievements UserDogAchievement[]
}

model DogSkillCategory {
  id        String @id
  nameDe    String
  nameEn    String
  emoji     String
  sortOrder Int    @default(0)

  skills DogSkillDefinition[]
}

model DogSkillDefinition {
  id               String  @id
  categoryId       String
  nameDe           String
  nameEn           String
  descriptionDe    String
  descriptionEn    String
  difficulty       String
  phase            String
  prerequisiteIds  String?
  isSystem         Boolean @default(false)
  createdById      String?
  sortOrder        Int     @default(0)
  createdAt        DateTime @default(now())

  category      DogSkillCategory     @relation(fields: [categoryId], references: [id])
  createdBy     User?                @relation("DogSkillCreatedBy", fields: [createdById], references: [id])
  progresses    DogSkillProgress[]
  sessionSkills DogSessionSkill[]

  @@index([categoryId])
}

model DogSkillProgress {
  id                String    @id @default(cuid())
  dogId             String
  skillDefinitionId String
  status            String    @default("new")
  progress          Float     @default(0)
  bestStatus        String    @default("new")
  trainedCount      Int       @default(0)
  firstTrainedAt    DateTime?
  lastTrainedAt     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dog             Dog                @relation(fields: [dogId], references: [id], onDelete: Cascade)
  skillDefinition DogSkillDefinition @relation(fields: [skillDefinitionId], references: [id])

  @@unique([dogId, skillDefinitionId])
  @@index([dogId])
}

model DogTrainingSession {
  id               String    @id @default(cuid())
  dogId            String
  userId           String
  withUserId       String?
  durationMinutes  Int
  moodLevel        String?
  sessionType      String?
  notes            String?
  pointsAwarded    Int
  taskCompletionId String?
  completedAt      DateTime  @default(now())

  dog            Dog              @relation(fields: [dogId], references: [id], onDelete: Cascade)
  user           User             @relation("DogSessionUser", fields: [userId], references: [id])
  withUser       User?            @relation("DogSessionWithUser", fields: [withUserId], references: [id])
  taskCompletion TaskCompletion?  @relation(fields: [taskCompletionId], references: [id])
  skillsTrained  DogSessionSkill[]

  @@index([dogId])
  @@index([userId])
  @@index([completedAt])
}

model DogSessionSkill {
  id                String @id @default(cuid())
  sessionId         String
  skillDefinitionId String
  rating            String

  session         DogTrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  skillDefinition DogSkillDefinition @relation(fields: [skillDefinitionId], references: [id])

  @@unique([sessionId, skillDefinitionId])
  @@index([sessionId])
}

model DogAchievement {
  id             String @id
  titleDe        String
  titleEn        String
  descriptionDe  String
  descriptionEn  String
  emoji          String
  conditionType  String
  conditionValue Int
  conditionMeta  String?
  sortOrder      Int    @default(0)

  userDogAchievements UserDogAchievement[]
}

model UserDogAchievement {
  id            String   @id @default(cuid())
  userId        String
  dogId         String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User           @relation("DogUserAchievement", fields: [userId], references: [id], onDelete: Cascade)
  dog         Dog            @relation(fields: [dogId], references: [id], onDelete: Cascade)
  achievement DogAchievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, dogId, achievementId])
  @@index([dogId])
}
