{
  "name": "chore-quest",
  "version": "1.0.0",
  "description": "A gamified household task manager for couples",
  "license": "MIT",
  "keywords": [
    "household",
    "gamification",
    "tasks",
    "nextjs",
    "prisma",
    "couples"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FrFrey98/chore-quest.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "npx prisma db seed",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "test:e2e": "mkdir -p e2e/.auth && DATABASE_URL=file:./test.db npx prisma migrate dev && DATABASE_URL=file:./test.db npm run seed && playwright test",
    "test:e2e:ui": "mkdir -p e2e/.auth && DATABASE_URL=file:./test.db npx prisma migrate dev && DATABASE_URL=file:./test.db npm run seed && playwright test --ui"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.13",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8",
    "prisma": "^7.6.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
